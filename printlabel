#!/usr/bin/env bash

usage() {
  cat <<EOF
Usage:
  $(basename "$0") [options] TEXT
  $(basename "$0") [options] --image PATH
  $(basename "$0") [options] --qr TEXT [LABEL_TEXT ...]
  $(basename "$0") [options] --netbox [QUERY]

Options:
  -h, --help           Show this help message
  -v, --version        Show version information
  -p, --printer MAC    Use the given printer MAC address
  -c, --count N        Print the same label N times
      --image PATH     Print an existing image file
      --qr TEXT        Generate and print a QR code (optionally with right-side label text)
      --netbox [QUERY] Resolve a NetBox device, rack, module, or inventory item by id, name, serial, or asset tag
      --simple         In NetBox mode, print only QR code and asset tag
      --netbox-url URL NetBox base URL, overrides NETBOX_URL
      --netbox-token T NetBox API token, overrides NETBOX_API_TOKEN
      --qr-size PX     Set QR size in pixels before padding
      --black          Invert QR codes for black tape
      --invert         Invert black and white
      --preview        Preview in terminal when possible
      --raw            Skip image preprocessing for --image

Examples:
  $(basename "$0") 'HELLO'
  $(basename "$0") --printer 98:6E:E8:47:C9:A3 --image label.png
  $(basename "$0") --count 3 'HELLO'
  $(basename "$0") --qr 'https://example.com' --preview
  $(basename "$0") --qr 'https://example.com' test1234
  $(basename "$0") --netbox 123 --netbox-url https://netbox.example.com
  $(basename "$0") --netbox Schmutzi
  $(basename "$0") --netbox
  $(basename "$0") --netbox 123 --simple
  $(basename "$0") --qr 'https://example.com' --black
EOF
}

print_version() {
  printf '%s\n' "${PRINTLABEL_VERSION:-dev}"
}

PRINTLABEL_COLOR_STDOUT=""
PRINTLABEL_COLOR_STDERR=""

supports_color() {
  local fd="${1:-1}"

  if [[ "${fd}" -eq 2 ]]
  then
    [[ -n "${PRINTLABEL_COLOR_STDERR:-}" ]]
    return $?
  fi

  [[ -n "${PRINTLABEL_COLOR_STDOUT:-}" ]]
}

init_color_support() {
  if [[ -n "${PRINTLABEL_FORCE_COLOR:-}" ]]
  then
    PRINTLABEL_COLOR_STDOUT=1
    PRINTLABEL_COLOR_STDERR=1
    return 0
  fi

  if [[ -t 1 ]]
  then
    PRINTLABEL_COLOR_STDOUT=1
  fi

  if [[ -t 2 ]]
  then
    PRINTLABEL_COLOR_STDERR=1
  fi
}

color_code() {
  local name="$1"

  case "${name}" in
    red)
      printf '%s' '31'
      ;;
    green)
      printf '%s' '32'
      ;;
    yellow)
      printf '%s' '33'
      ;;
    blue)
      printf '%s' '34'
      ;;
    cyan)
      printf '%s' '36'
      ;;
    gray)
      printf '%s' '90'
      ;;
    bold)
      printf '%s' '1'
      ;;
    strikethrough)
      printf '%s' '9'
      ;;
    *)
      return 1
      ;;
  esac
}

colorize() {
  local name="$1"
  local text="$2"
  local fd="${3:-1}"
  local code

  if ! supports_color "${fd}"
  then
    printf '%s' "${text}"
    return 0
  fi

  code="$(color_code "${name}")" || {
    printf '%s' "${text}"
    return 0
  }

  printf '\033[%sm%s\033[0m' "${code}" "${text}"
}

colorize_multi() {
  local style_names="$1"
  local text="$2"
  local fd="${3:-1}"
  local style_name
  local code
  local codes=()

  if ! supports_color "${fd}"
  then
    printf '%s' "${text}"
    return 0
  fi

  for style_name in ${style_names}
  do
    code="$(color_code "${style_name}")" || continue
    codes+=("${code}")
  done

  if [[ "${#codes[@]}" -eq 0 ]]
  then
    printf '%s' "${text}"
    return 0
  fi

  printf '\033[%sm%s\033[0m' "$(IFS=';'; printf '%s' "${codes[*]}")" "${text}"
}

netbox_value_color() {
  local key="$1"

  case "${key}" in
    Type)
      printf '%s' 'cyan'
      ;;
    ID|Asset\ tag|Serial)
      printf '%s' 'yellow'
      ;;
    Name|Manufacturer|Device\ type|Role|Site|Location)
      printf '%s' 'green'
      ;;
    URL)
      printf '%s' 'blue'
      ;;
    *)
      printf '%s' 'cyan'
      ;;
  esac
}

log_info() {
  local message="$1"

  printf '%s %s\n' "$(colorize blue 'INF' 2)" "${message}" >&2
}

log_warn() {
  local message="$1"

  printf '%s %s\n' "$(colorize yellow 'WRN' 2)" "${message}" >&2
}

log_error() {
  local message="$1"

  printf '%s %s\n' "$(colorize red 'ERR' 2)" "${message}" >&2
}

cleanup() {
  if [[ -n "${label_image:-}" && -f "${label_image}" ]]
  then
    rm -f "${label_image}"
  fi
}

find_magick() {
  if command -v magick >/dev/null 2>&1
  then
    printf '%s\n' "magick"
    return 0
  fi

  if command -v convert >/dev/null 2>&1
  then
    printf '%s\n' "convert"
    return 0
  fi

  log_error "ImageMagick is required but neither 'magick' nor 'convert' was found."
  return 1
}

find_font() {
  local font_name

  if command -v fc-match >/dev/null 2>&1
  then
    font_name="$(fc-match -f '%{file}\n' sans 2>/dev/null | head -n 1)"
  fi

  if [[ -n "${font_name:-}" ]]
  then
    printf '%s\n' "${font_name}"
    return 0
  fi

  printf '%s\n' "DejaVu Sans"
}

find_qrencode() {
  if command -v qrencode >/dev/null 2>&1
  then
    printf '%s\n' "qrencode"
    return 0
  fi

  log_error "qrencode is required for --qr mode."
  return 1
}

find_jq() {
  if command -v jq >/dev/null 2>&1
  then
    printf '%s\n' "jq"
    return 0
  fi

  log_error "jq is required for --netbox mode."
  return 1
}

find_nbx() {
  if command -v nbx >/dev/null 2>&1
  then
    printf '%s\n' "nbx"
    return 0
  fi

  log_error "nbx is required for --netbox mode."
  return 1
}

find_fzf() {
  if command -v fzf >/dev/null 2>&1
  then
    printf '%s\n' "fzf"
    return 0
  fi

  log_error "fzf is required to choose between multiple NetBox devices."
  return 1
}

normalize_label_line() {
  local text="$1"

  text="${text//$'\r'/ }"
  text="${text//$'\n'/ }"
  text="${text//$'\t'/ }"
  text="$(awk '{$1=$1; print}' <<< "${text}")"

  printf '%s\n' "${text}"
}

is_bdaddr() {
  local value="$1"

  [[ "${value}" =~ ^([[:xdigit:]]{2}:){5}[[:xdigit:]]{2}$ ]]
}

list_printer_candidates() {
  bluetoothctl <<< "devices" | awk '
    $1 == "Device" && $3 ~ /^PT-P[0-9].*BT/ {
      print $2
    }
  '
}

get_device_info() {
  local printer_address="$1"

  bluetoothctl <<< "info ${printer_address}" 2>/dev/null
}

prepare_printer_connection() {
  local printer_address="$1"

  bluetoothctl --timeout 3 scan on >/dev/null 2>&1 || true
  bluetoothctl <<< "trust ${printer_address}" >/dev/null 2>&1 || true
  bluetoothctl <<< "connect ${printer_address}" >/dev/null 2>&1 || true
  sleep 2
}

discover_printer_address() {
  local configured_address="${1:-${PRINTLABEL_PRINTER:-}}"
  local candidates=()
  local preferred_candidates=()
  local printer_address
  local info

  if [[ -n "${configured_address}" ]]
  then
    if ! is_bdaddr "${configured_address}"
    then
      echo "PRINTLABEL_PRINTER is not a valid Bluetooth MAC address: ${configured_address}" >&2
      return 1
    fi
    printf '%s\n' "${configured_address}"
    return 0
  fi

  mapfile -t candidates < <(list_printer_candidates)

  if [[ ${#candidates[@]} -eq 0 ]]
  then
    echo "No known printer found. Scanning for nearby Brother label printers..." >&2
    bluetoothctl --timeout 5 scan on >/dev/null 2>&1 || true
    mapfile -t candidates < <(list_printer_candidates)
  fi

  if [[ ${#candidates[@]} -eq 0 ]]
  then
    echo "No Brother P-Touch printer was discovered." >&2
    return 1
  fi

  if [[ ${#candidates[@]} -eq 1 ]]
  then
    printf '%s\n' "${candidates[0]}"
    return 0
  fi

  for printer_address in "${candidates[@]}"
  do
    info="$(get_device_info "${printer_address}")"
    if grep -Eq '^(\t| )*Trusted: yes$' <<< "${info}" || grep -Eq '^(\t| )*Paired: yes$' <<< "${info}"
    then
      preferred_candidates+=("${printer_address}")
    fi
  done

  if [[ ${#preferred_candidates[@]} -eq 1 ]]
  then
    printf '%s\n' "${preferred_candidates[0]}"
    return 0
  fi

  echo "Multiple Brother label printers were found. Set PRINTLABEL_PRINTER or pass the MAC address explicitly." >&2
  printf '%s\n' "${candidates[@]}" >&2
  return 1
}

apply_invert() {
  local image_tool="$1"
  local source_image="$2"
  local target_image="$3"

  "${image_tool}" \
    "${source_image}" \
    -negate \
    "${target_image}"
}

can_preview_with_kitty() {
  if [[ -z "${KITTY_WINDOW_ID:-}" ]]
  then
    return 1
  fi

  if ! command -v kitten >/dev/null 2>&1
  then
    return 1
  fi

  if [[ -n "${PRINTLABEL_FORCE_KITTY:-}" ]]
  then
    return 0
  fi

  if ! [[ -t 1 ]]
  then
    return 1
  fi

  kitten icat --detect-support >/dev/null 2>&1
}

preview_label_with_kitty() {
  local reply

  printf '\n'
  printf '%s\n' "$(colorize_multi 'bold cyan' 'Label preview' 1)"
  kitten icat --stdin=no --transfer-mode=detect --align=left "${label_image}" || return 1
  printf '\nPrint? (y|n) '
  IFS= read -r -n 1 reply
  printf '\n'
  kitten icat --clear-all >/dev/null 2>&1 || true
  if [[ "${reply}" != "y" ]]
  then
    echo "Aborted."
    return 1
  fi
}

render_label() {
  local label_text="$1"
  local image_tool="$2"
  local font_name="$3"

  if [[ "${label_text}" =~ [\]jgpq\|\\\$/@_(){}\[] ]]
  then
    "${image_tool}" \
      -background white \
      -fill black \
      -font "${font_name}" \
      -size x82 \
      -gravity south \
      "label:${label_text}" \
      -splice 0x15 \
      "${label_image}"
    echo "standard mode"
  else
    "${image_tool}" \
      -background white \
      -fill black \
      -font "${font_name}" \
      -pointsize 86 \
      "label:${label_text}" \
      -splice 0x5 \
      -bordercolor white \
      -border 10x10 \
      "${label_image}"
    echo "UPPERCASE MODE (bigger font)"
  fi
}

render_qr() {
  local qr_text="$1"
  local image_tool="$2"
  local qr_tool="$3"
  local qr_size="$4"
  local black_mode="$5"
  local qr_source_image

  if [[ ! "${qr_size}" =~ ^[0-9]+$ ]] || [[ "${qr_size}" -le 0 ]]
  then
    echo "QR size must be a positive integer." >&2
    return 1
  fi

  qr_source_image="$(mktemp --suffix=.png printlabel-qr.XXXXXX)"

  "${qr_tool}" \
    --level=M \
    --margin=1 \
    --size=1 \
    --type=PNG \
    --output="${qr_source_image}" \
    "${qr_text}" || return 1

  "${image_tool}" \
    "${qr_source_image}" \
    -filter point \
    -resize "${qr_size}x${qr_size}" \
    -gravity center \
    -background white \
    -extent "${qr_size}x${qr_size}" \
    "${label_image}" || return 1

  if [[ -n "${black_mode}" ]]
  then
    apply_invert "${image_tool}" "${label_image}" "${label_image}" || return 1
  fi

  rm -f "${qr_source_image}"
  echo "QR mode (${qr_size}px)"
}

render_qr_with_text() {
  local qr_text="$1"
  local text_block="$2"
  local image_tool="$3"
  local qr_tool="$4"
  local font_name="$5"
  local qr_size="$6"
  local black_mode="$7"
  local qr_source_image
  local qr_image
  local text_image
  local text_dimensions
  local text_height
  local text_pointsize=20
  local text_width
  local qr_gap=4
  local text_padding=8

  if [[ ! "${qr_size}" =~ ^[0-9]+$ ]] || [[ "${qr_size}" -le 0 ]]
  then
    echo "QR size must be a positive integer." >&2
    return 1
  fi

  qr_source_image="$(mktemp --suffix=.png printlabel-qr.XXXXXX)"
  qr_image="$(mktemp --suffix=.png printlabel-qr-rendered.XXXXXX)"
  text_image="$(mktemp --suffix=.png printlabel-text.XXXXXX)"

  "${qr_tool}" \
    --level=M \
    --margin=1 \
    --size=1 \
    --type=PNG \
    --output="${qr_source_image}" \
    "${qr_text}" || return 1

  "${image_tool}" \
    "${qr_source_image}" \
    -filter point \
    -resize "${qr_size}x${qr_size}" \
    -gravity center \
    -background white \
    -extent "${qr_size}x${qr_size}" \
    "${qr_image}" || return 1

  if [[ -n "${black_mode}" ]]
  then
    apply_invert "${image_tool}" "${qr_image}" "${qr_image}" || return 1
  fi

  text_block="$(normalize_label_line "${text_block}")"
  while [[ "${text_pointsize}" -ge 8 ]]
  do
    text_dimensions="$(
      "${image_tool}" \
        -background white \
        -fill black \
        -font "${font_name}" \
        -pointsize "${text_pointsize}" \
        "label:${text_block}" \
        -format '%w %h' \
        info:
    )" || return 1

    read -r text_width text_height <<< "${text_dimensions}"

    if [[ "${text_width}" =~ ^[0-9]+$ && "${text_height}" =~ ^[0-9]+$ ]]
    then
      if (( text_height <= qr_size ))
      then
        break
      fi
    fi

    text_pointsize=$((text_pointsize - 1))
  done

  if [[ ! "${text_width}" =~ ^[0-9]+$ || ! "${text_height}" =~ ^[0-9]+$ ]]
  then
    echo "Failed to determine QR text dimensions." >&2
    return 1
  fi

  if (( text_height > qr_size ))
  then
    echo "QR text block is too tall to fit on the label." >&2
    return 1
  fi

  text_width=$((text_width + text_padding))

  "${image_tool}" \
    -background white \
    -fill black \
    -font "${font_name}" \
    -pointsize "${text_pointsize}" \
    -gravity west \
    "label:${text_block}" \
    -bordercolor white \
    -border "${qr_gap}x0" \
    -extent "${text_width}x${qr_size}" \
    "${text_image}" || return 1

  "${image_tool}" \
    "${qr_image}" \
    "${text_image}" \
    +append \
    "${label_image}" || return 1

  rm -f "${qr_source_image}" "${qr_image}" "${text_image}"
  echo "QR + text mode (${qr_size}px QR)"
}

fetch_netbox_objects() {
  local nbx_bin="$1"
  local jq_bin="$2"
  local netbox_url="$3"
  local netbox_token="$4"
  local netbox_query="${5:-}"
  local response
  local devices_response
  local racks_response
  local modules_response
  local inventory_items_response
  local exact_matches
  local search_matches
  local devices_file
  local racks_file
  local modules_file
  local inventory_items_file

  devices_file="$(mktemp printlabel-netbox-devices.XXXXXX.json)" || return 1
  racks_file="$(mktemp printlabel-netbox-racks.XXXXXX.json)" || {
    rm -f "${devices_file}"
    return 1
  }
  modules_file="$(mktemp printlabel-netbox-modules.XXXXXX.json)" || {
    rm -f "${devices_file}" "${racks_file}"
    return 1
  }
  inventory_items_file="$(mktemp printlabel-netbox-inventory-items.XXXXXX.json)" || {
    rm -f "${devices_file}" "${racks_file}" "${modules_file}"
    return 1
  }

  if [[ -z "${netbox_query}" ]]
  then
    devices_response="$(
      NETBOX_URL="${netbox_url}" \
        NETBOX_API_TOKEN="${netbox_token}" \
        "${nbx_bin}" -j devices
    )" || return 1
    racks_response="$(
      NETBOX_URL="${netbox_url}" \
        NETBOX_API_TOKEN="${netbox_token}" \
        "${nbx_bin}" -j racks
    )" || return 1
    modules_response="$(
      NETBOX_URL="${netbox_url}" \
        NETBOX_API_TOKEN="${netbox_token}" \
        "${nbx_bin}" -j modules
    )" || return 1
    inventory_items_response="$(
      NETBOX_URL="${netbox_url}" \
        NETBOX_API_TOKEN="${netbox_token}" \
        "${nbx_bin}" -j inventory-items
    )" || return 1

    printf '%s\n' "${devices_response}" > "${devices_file}"
    printf '%s\n' "${racks_response}" > "${racks_file}"
    printf '%s\n' "${modules_response}" > "${modules_file}"
    printf '%s\n' "${inventory_items_response}" > "${inventory_items_file}"

    # shellcheck disable=SC2016
    "${jq_bin}" -s '
      [
        (.[0][] | . + {printlabel_kind: "device"}),
        (.[1][] | . + {printlabel_kind: "rack"}),
        (.[2][] | . + {printlabel_kind: "module"}),
        (.[3][] | . + {printlabel_kind: "inventory-item"})
      ]
      | unique_by(.printlabel_kind, .id)
      | sort_by(.name // .label // .module_type.model // .module_bay.name // "", .asset_tag // "", .serial // "", .id)
    ' "${devices_file}" "${racks_file}" "${modules_file}" "${inventory_items_file}"
    rm -f "${devices_file}" "${racks_file}" "${modules_file}" "${inventory_items_file}"
    return $?
  fi

  if [[ "${netbox_query}" =~ ^[0-9]+$ ]]
  then
    devices_response="$(
      NETBOX_URL="${netbox_url}" \
        NETBOX_API_TOKEN="${netbox_token}" \
        "${nbx_bin}" -j devices "id=${netbox_query}"
    )" || return 1
    racks_response="$(
      NETBOX_URL="${netbox_url}" \
        NETBOX_API_TOKEN="${netbox_token}" \
        "${nbx_bin}" -j racks "id=${netbox_query}"
    )" || return 1
    modules_response="$(
      NETBOX_URL="${netbox_url}" \
        NETBOX_API_TOKEN="${netbox_token}" \
        "${nbx_bin}" -j modules "id=${netbox_query}"
    )" || return 1
    inventory_items_response="$(
      NETBOX_URL="${netbox_url}" \
        NETBOX_API_TOKEN="${netbox_token}" \
        "${nbx_bin}" -j inventory-items "id=${netbox_query}"
    )" || return 1

    printf '%s\n' "${devices_response}" > "${devices_file}"
    printf '%s\n' "${racks_response}" > "${racks_file}"
    printf '%s\n' "${modules_response}" > "${modules_file}"
    printf '%s\n' "${inventory_items_response}" > "${inventory_items_file}"

    response="$(
      # shellcheck disable=SC2016
      "${jq_bin}" -s '
        [
          (.[0][] | . + {printlabel_kind: "device"}),
          (.[1][] | . + {printlabel_kind: "rack"}),
          (.[2][] | . + {printlabel_kind: "module"}),
          (.[3][] | . + {printlabel_kind: "inventory-item"})
        ]
        | unique_by(.printlabel_kind, .id)
        | sort_by(.name // .label // .module_type.model // .module_bay.name // "", .asset_tag // "", .serial // "", .id)
      ' "${devices_file}" "${racks_file}" "${modules_file}" "${inventory_items_file}"
    )" || return 1

    rm -f "${devices_file}" "${racks_file}" "${modules_file}" "${inventory_items_file}"

    if [[ "$("${jq_bin}" -r 'length' <<< "${response}")" -gt 0 ]]
    then
      printf '%s\n' "${response}"
      return 0
    fi
  fi

  devices_response="$(
    NETBOX_URL="${netbox_url}" \
      NETBOX_API_TOKEN="${netbox_token}" \
      "${nbx_bin}" -j devices "q=${netbox_query}"
  )" || return 1
  racks_response="$(
    NETBOX_URL="${netbox_url}" \
      NETBOX_API_TOKEN="${netbox_token}" \
      "${nbx_bin}" -j racks "q=${netbox_query}"
  )" || return 1
  modules_response="$(
    NETBOX_URL="${netbox_url}" \
      NETBOX_API_TOKEN="${netbox_token}" \
      "${nbx_bin}" -j modules "q=${netbox_query}"
  )" || return 1
  inventory_items_response="$(
    NETBOX_URL="${netbox_url}" \
      NETBOX_API_TOKEN="${netbox_token}" \
      "${nbx_bin}" -j inventory-items "q=${netbox_query}"
  )" || return 1

  printf '%s\n' "${devices_response}" > "${devices_file}"
  printf '%s\n' "${racks_response}" > "${racks_file}"
  printf '%s\n' "${modules_response}" > "${modules_file}"
  printf '%s\n' "${inventory_items_response}" > "${inventory_items_file}"

  search_matches="$(
    # shellcheck disable=SC2016
    "${jq_bin}" -s '
      [
        (.[0][] | . + {printlabel_kind: "device"}),
        (.[1][] | . + {printlabel_kind: "rack"}),
        (.[2][] | . + {printlabel_kind: "module"}),
        (.[3][] | . + {printlabel_kind: "inventory-item"})
      ]
    ' "${devices_file}" "${racks_file}" "${modules_file}" "${inventory_items_file}"
  )" || return 1

  rm -f "${devices_file}" "${racks_file}" "${modules_file}" "${inventory_items_file}"

  exact_matches="$(
    # shellcheck disable=SC2016
    "${jq_bin}" -c --arg query "${netbox_query}" '
      map(
        select(
          (.name // "" | ascii_downcase) == ($query | ascii_downcase)
          or (.label // "" | ascii_downcase) == ($query | ascii_downcase)
          or (.module_type.model // "" | ascii_downcase) == ($query | ascii_downcase)
          or (.module_bay.name // "" | ascii_downcase) == ($query | ascii_downcase)
          or (.serial // "" | ascii_downcase) == ($query | ascii_downcase)
          or (.asset_tag // "" | ascii_downcase) == ($query | ascii_downcase)
        )
      )
      | unique_by(.printlabel_kind, .id)
      | sort_by(.name // .label // .module_type.model // .module_bay.name // "", .asset_tag // "", .serial // "", .id)
    ' <<< "${search_matches}"
  )" || return 1

  if [[ "$("${jq_bin}" -r 'length' <<< "${exact_matches}")" -gt 0 ]]
  then
    printf '%s\n' "${exact_matches}"
    return 0
  fi

  "${jq_bin}" '
    unique_by(.printlabel_kind, .id)
    | sort_by(.name // .label // .module_type.model // .module_bay.name // "", .asset_tag // "", .serial // "", .id)
  ' <<< "${search_matches}"
}

select_netbox_object() {
  local nbx_bin="$1"
  local jq_bin="$2"
  local netbox_url="$3"
  local netbox_token="$4"
  local netbox_query="${5:-}"
  local fzf_bin
  local objects_json
  local object_count
  local narrowed_json=""
  local narrowed_count=""
  local selected_line
  local selected_index
  local cache_file
  local candidates_file
  local selection_file
  local preview_command
  local preview_nbx_bin
  local preview_cache
  local preview_netbox_url
  local preview_netbox_token
  local -a fzf_args

  objects_json="$(
    fetch_netbox_objects "${nbx_bin}" "${jq_bin}" "${netbox_url}" "${netbox_token}" "${netbox_query}"
  )" || return 1

  object_count="$("${jq_bin}" -r 'length' <<< "${objects_json}")" || return 1

  if [[ "${object_count}" -eq 0 ]]
  then
    if [[ -n "${netbox_query}" ]]
    then
      log_error "No NetBox device, rack, module, or inventory item matched '${netbox_query}'."
    else
      log_error "No NetBox devices, racks, modules, or inventory items found."
    fi
    return 1
  fi

  if [[ "${object_count}" -eq 1 ]]
  then
    "${jq_bin}" -c '.[0]' <<< "${objects_json}"
    return 0
  fi

  if [[ -n "${netbox_query}" ]]
  then
    narrowed_json="$(
      # shellcheck disable=SC2016
      "${jq_bin}" -c --arg query "${netbox_query}" '
        map(
          select(
            (.name // "" | ascii_downcase | contains($query | ascii_downcase))
            or (.label // "" | ascii_downcase | contains($query | ascii_downcase))
            or (.module_type.model // "" | ascii_downcase | contains($query | ascii_downcase))
            or (.module_bay.name // "" | ascii_downcase | contains($query | ascii_downcase))
            or (.serial // "" | ascii_downcase | contains($query | ascii_downcase))
            or (.asset_tag // "" | ascii_downcase | contains($query | ascii_downcase))
          )
        )
      ' <<< "${objects_json}"
    )" || return 1

    narrowed_count="$("${jq_bin}" -r 'length' <<< "${narrowed_json}")" || return 1

    if [[ "${narrowed_count}" -gt 0 ]]
    then
      objects_json="${narrowed_json}"
      object_count="${narrowed_count}"
    fi
  fi

  if [[ "${object_count}" -eq 1 ]]
  then
    "${jq_bin}" -c '.[0]' <<< "${objects_json}"
    return 0
  fi

  fzf_bin="$(find_fzf)" || return 1
  cache_file="$(mktemp printlabel-netbox-objects.XXXXXX.json)"
  candidates_file="$(mktemp printlabel-netbox-candidates.XXXXXX.tsv)"
  selection_file="$(mktemp printlabel-netbox-selection.XXXXXX.txt)"
  printf '%s\n' "${objects_json}" > "${cache_file}"
  printf -v preview_nbx_bin '%q' "${nbx_bin}"
  printf -v preview_cache '%q' "${cache_file}"
  printf -v preview_netbox_url '%q' "${netbox_url}"
  printf -v preview_netbox_token '%q' "${netbox_token}"
  preview_command="NBX_FORCE_COLOR=1 NBX_FORCE_KITTY=1 NETBOX_URL=${preview_netbox_url} NETBOX_API_TOKEN=${preview_netbox_token} ${preview_nbx_bin} --fzf-preview {2} ${preview_cache} {1}"
  fzf_args=(
    --ansi
    --delimiter=$'\t'
    "--with-nth=4"
    --prompt='NetBox object> '
    --header='Select a device, rack, module, or inventory item to print'
    --preview-window='right:60%:wrap'
    --preview "${preview_command}"
  )

  if [[ -n "${netbox_query}" ]]
  then
    fzf_args+=(--query "${netbox_query}")
  fi

  "${jq_bin}" -r '
    to_entries[] |
    [
      (.key | tostring),
      (.value.printlabel_kind // ""),
      (.value.id | tostring),
      (.value.name // .value.label // .value.module_type.model // .value.module_bay.name // ""),
      (.value.asset_tag // ""),
      (.value.serial // ""),
      (.value.role.name // .value.module_bay.name // ""),
      (.value.site.name // .value.device.site.name // .value.rack.site.name // "")
    ] | @tsv
  ' "${cache_file}" > "${candidates_file}" || {
    rm -f "${cache_file}" "${candidates_file}" "${selection_file}"
    return 1
  }

  "${fzf_bin}" "${fzf_args[@]}" < "${candidates_file}" > "${selection_file}" || {
    rm -f "${cache_file}"
    rm -f "${candidates_file}" "${selection_file}"
    return 1
  }

  selected_line="$(< "${selection_file}")"
  rm -f "${candidates_file}" "${selection_file}"

  selected_index="${selected_line%%$'\t'*}"
  # shellcheck disable=SC2016
  "${jq_bin}" -c --arg index "${selected_index}" '
    .[$index | tonumber]
  ' "${cache_file}"
  rm -f "${cache_file}"
}

render_netbox_label() {
  local image_tool="$1"
  local qr_tool="$2"
  local object_url="$3"
  local object_name="$4"
  local asset_tag="$5"
  local serial_number="$6"
  local font_name="$7"
  local qr_size="$8"
  local black_mode="$9"
  local simple_mode="${10}"
  local qr_source_image
  local qr_image
  local text_image
  local text_block=""
  local text_dimensions
  local text_height
  local text_pointsize=14
  local simple_text_pointsize=20
  local text_width
  local qr_gap=4
  local text_padding=8

  qr_source_image="$(mktemp --suffix=.png printlabel-qr.XXXXXX)"
  qr_image="$(mktemp --suffix=.png printlabel-qr-rendered.XXXXXX)"
  text_image="$(mktemp --suffix=.png printlabel-text.XXXXXX)"

  "${qr_tool}" \
    --level=M \
    --margin=1 \
    --size=1 \
    --type=PNG \
    --output="${qr_source_image}" \
    "${object_url}" || return 1

  "${image_tool}" \
    "${qr_source_image}" \
    -filter point \
    -resize "${qr_size}x${qr_size}" \
    -gravity center \
    -background white \
    -extent "${qr_size}x${qr_size}" \
    "${qr_image}" || return 1

  if [[ -n "${black_mode}" ]]
  then
    apply_invert "${image_tool}" "${qr_image}" "${qr_image}" || return 1
  fi

  asset_tag="$(normalize_label_line "${asset_tag}")"
  if [[ -n "${simple_mode}" ]]
  then
    text_pointsize="${simple_text_pointsize}"
    text_block="${asset_tag}"
  else
    object_name="$(normalize_label_line "${object_name}")"
    serial_number="$(normalize_label_line "${serial_number}")"

    text_block="${object_name}"
    if [[ -n "${asset_tag}" ]]
    then
      text_block="${text_block}"$'\n'"${asset_tag}"
    fi
    if [[ -n "${serial_number}" ]]
    then
      text_block="${text_block}"$'\n'"${serial_number}"
    fi
  fi

  while [[ "${text_pointsize}" -ge 8 ]]
  do
    text_dimensions="$(
      "${image_tool}" \
        -background white \
        -fill black \
        -font "${font_name}" \
        -pointsize "${text_pointsize}" \
        "label:${text_block}" \
        -format '%w %h' \
        info:
    )" || return 1

    read -r text_width text_height <<< "${text_dimensions}"

    if [[ "${text_width}" =~ ^[0-9]+$ && "${text_height}" =~ ^[0-9]+$ ]]
    then
      if (( text_height <= qr_size ))
      then
        break
      fi
    fi

    text_pointsize=$((text_pointsize - 1))
  done

  if [[ ! "${text_width}" =~ ^[0-9]+$ || ! "${text_height}" =~ ^[0-9]+$ ]]
  then
    echo "Failed to determine NetBox text dimensions." >&2
    return 1
  fi

  if (( text_height > qr_size ))
  then
    echo "NetBox text block is too tall to fit on the label." >&2
    return 1
  fi

  text_width=$((text_width + text_padding))

  "${image_tool}" \
    -background white \
    -fill black \
    -font "${font_name}" \
    -pointsize "${text_pointsize}" \
    -gravity west \
    "label:${text_block}" \
    -bordercolor white \
    -border "${qr_gap}x0" \
    -extent "${text_width}x${qr_size}" \
    "${text_image}" || return 1

  "${image_tool}" \
    "${qr_image}" \
    "${text_image}" \
    +append \
    "${label_image}" || return 1

  rm -f "${qr_source_image}" "${qr_image}" "${text_image}"
}

print_netbox_summary() {
  local jq_bin="$1"
  local netbox_object_json="$2"
  local summary_lines
  local key
  local value
  local value_color
  local width

  width="$("${jq_bin}" -r '
    [
      "Type",
      "ID",
      "Name",
      "Manufacturer",
      "Model",
      "Asset tag",
      "Serial",
      "Role",
      "Site",
      "Location",
      "URL"
    ] | map(length) | max
  ' <<< "${netbox_object_json}")" || return 1

  summary_lines="$("${jq_bin}" -r '
    [
      "Type\t" + (.printlabel_kind // "unknown"),
      "ID\t" + ((.id // "") | tostring),
      "Name\t" + (.name // .label // .module_type.model // .module_bay.name // ""),
      "Manufacturer\t" + (.device_type.manufacturer.name // .module_type.manufacturer.name // .manufacturer.name // ""),
      "Model\t" + (.device_type.model // .module_type.model // .part_id // ""),
      "Asset tag\t" + (.asset_tag // ""),
      "Serial\t" + (.serial // ""),
      "Role\t" + (.role.name // .module_bay.name // ""),
      "Site\t" + (.site.name // .device.site.name // .rack.site.name // ""),
      "Location\t" + (.location.name // .device.location.name // .rack.location.name // ""),
      "URL\t" + (.display_url // "")
    ] | join("\n")
  ' <<< "${netbox_object_json}")" || return 1

  while IFS=$'\t' read -r key value
  do
    if [[ -z "${value}" ]]
    then
      value="$(colorize_multi 'gray strikethrough' 'N/A' 1)"
    else
      value_color="$(netbox_value_color "${key}")"
      value="$(colorize "${value_color}" "${value}" 1)"
    fi
    printf '%s  %s\n' \
      "$(colorize_multi 'bold cyan' "$(printf '%-*s' "${width}" "${key}")" 1)" \
      "${value}"
  done <<< "${summary_lines}"
}

preview_label() {
  local preview_mode="${1:-}"

  if [[ -z "${preview_mode}" ]]
  then
    return 0
  fi

  if can_preview_with_kitty
  then
    preview_label_with_kitty
    return $?
  fi

  if ! command -v display >/dev/null 2>&1
  then
    log_warn "Preview requested but 'display' is not installed. Continuing without preview."
    return 0
  fi

  log_info "Opening GUI preview. Close the window to continue printing."
  display "${label_image}"
  printf 'Print? (y|n) '
  IFS= read -r -n 1 reply
  printf '\n'
  if [[ "${reply}" != "y" ]]
  then
    log_warn "Aborted."
    return 1
  fi
}

main() {
  local image_tool
  local jq_bin
  local nbx_bin
  local font_name
  local label_text
  local netbox_object_id=""
  local netbox_object_json=""
  local netbox_object_kind=""
  local netbox_object_url=""
  local netbox_mode=""
  local netbox_query=""
  local netbox_token="${NETBOX_API_TOKEN:-}"
  local netbox_url="${NETBOX_URL:-}"
  local printer_address
  local script_dir
  local image_file=""
  local image_mode=""
  local black_mode=""
  local invert_mode=""
  local preview_mode=""
  local count="1"
  local qr_size="${PRINTLABEL_QR_SIZE:-64}"
  local qr_text=""
  local explicit_printer_address="${PRINTLABEL_PRINTER:-}"
  local raw_mode=""
  local simple_mode=""
  local labelmaker_args=()
  local -a positional_args=()
  local qr_tool
  local qr_label_text=""
  local object_name=""
  local asset_tag=""
  local serial_number=""
  local print_index

  script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
  init_color_support

  while [[ -n "${1:-}" ]]
  do
    case "$1" in
      -h|--help)
        usage
        return 0
        ;;
      -v|--version)
        print_version
        return 0
        ;;
      -p|--printer)
        if [[ -z "${2:-}" ]]
        then
          echo "Missing printer MAC after $1." >&2
          usage >&2
          return 2
        fi
        explicit_printer_address="$2"
        shift 2
        ;;
      -c|--count)
        if [[ -z "${2:-}" ]]
        then
          echo "Missing count after $1." >&2
          usage >&2
          return 2
        fi
        count="$2"
        shift 2
        ;;
      --netbox)
        netbox_mode=1
        image_mode=1
        if [[ -n "${2:-}" ]] && [[ ! "${2}" == -* ]]
        then
          netbox_query="$2"
          shift 2
        else
          netbox_query=""
          shift
        fi
        ;;
      --netbox-url)
        if [[ -z "${2:-}" ]]
        then
          echo "Missing URL after --netbox-url." >&2
          usage >&2
          return 2
        fi
        netbox_url="$2"
        shift 2
        ;;
      --netbox-token)
        if [[ -z "${2:-}" ]]
        then
          echo "Missing token after --netbox-token." >&2
          usage >&2
          return 2
        fi
        netbox_token="$2"
        shift 2
        ;;
      --simple)
        simple_mode=1
        shift
        ;;
      --image)
        if [[ -z "${2:-}" ]]
        then
          echo "Missing image path after --image." >&2
          usage >&2
          return 2
        fi
        image_file="$2"
        image_mode=1
        shift 2
        ;;
      --qr)
        if [[ -z "${2:-}" ]]
        then
          echo "Missing QR text after --qr." >&2
          usage >&2
          return 2
        fi
        qr_text="$2"
        image_mode=1
        shift 2
        ;;
      --raw)
        raw_mode=1
        shift
        ;;
      --preview)
        preview_mode=1
        shift
        ;;
      --qr-size)
        if [[ -z "${2:-}" ]]
        then
          echo "Missing size after --qr-size." >&2
          usage >&2
          return 2
        fi
        qr_size="$2"
        shift 2
        ;;
      --black)
        black_mode=1
        shift
        ;;
      --invert)
        invert_mode=1
        shift
        ;;
      *)
        break
        ;;
    esac
  done

  positional_args=("$@")

  if [[ -n "${image_file}" && -n "${qr_text}" ]]
  then
    echo "Use either --image or --qr, not both." >&2
    usage >&2
    return 2
  fi

  if [[ -n "${netbox_mode}" && ( -n "${image_file}" || -n "${qr_text}" ) ]]
  then
    echo "Use only one of --image, --qr, or --netbox." >&2
    usage >&2
    return 2
  fi

  if [[ -n "${simple_mode}" && -z "${netbox_mode}" ]]
  then
    echo "--simple can only be used with --netbox." >&2
    usage >&2
    return 2
  fi

  if [[ -n "${black_mode}" && -n "${invert_mode}" ]]
  then
    echo "Use either --black or --invert, not both." >&2
    usage >&2
    return 2
  fi

  if [[ ! "${count}" =~ ^[0-9]+$ ]] || [[ "${count}" -le 0 ]]
  then
    echo "Count must be a positive integer." >&2
    usage >&2
    return 2
  fi

  if [[ -n "${image_mode}" && -n "${netbox_mode}" && ${#positional_args[@]} -gt 0 ]]
  then
    usage >&2
    return 2
  fi

  if [[ -n "${image_mode}" && -n "${image_file}" && ${#positional_args[@]} -gt 0 ]]
  then
    usage >&2
    return 2
  fi

  if [[ -n "${image_mode}" && ${#positional_args[@]} -gt 0 && -z "${qr_text}" ]]
  then
    usage >&2
    return 2
  fi

  if [[ -z "${image_mode}" && ${#positional_args[@]} -lt 1 ]]
  then
    usage >&2
    return 2
  fi

  if [[ -n "${image_mode}" ]]
  then
    image_tool="$(find_magick)" || return 1
    if [[ -n "${image_file}" ]]
    then
      if [[ ! -f "${image_file}" ]]
      then
        echo "Image file not found: ${image_file}" >&2
        return 1
      fi
      if [[ -n "${invert_mode}" ]]
      then
        label_image="$(mktemp --suffix=.png printlabel.XXXXXX)"
        trap cleanup EXIT
        apply_invert "${image_tool}" "${image_file}" "${label_image}" || return 1
      else
        label_image="${image_file}"
      fi
      if [[ -n "${raw_mode}" ]]
      then
        labelmaker_args+=("-r")
      fi
      preview_label "${preview_mode}" || return 1
    elif [[ -n "${netbox_mode}" ]]
    then
      if [[ -z "${netbox_url}" ]]
      then
        echo "NetBox mode requires --netbox-url or NETBOX_URL." >&2
        return 2
      fi
      jq_bin="$(find_jq)" || return 1
      nbx_bin="$(find_nbx)" || return 1
      font_name="$(find_font)"
      qr_tool="$(find_qrencode)" || return 1
      label_image="$(mktemp --suffix=.png printlabel.XXXXXX)"
      trap cleanup EXIT

      netbox_object_json="$(
        select_netbox_object "${nbx_bin}" "${jq_bin}" "${netbox_url}" "${netbox_token}" "${netbox_query}"
      )" || return 1

      netbox_object_id="$("${jq_bin}" -r '.id' <<< "${netbox_object_json}")" || return 1
      netbox_object_kind="$("${jq_bin}" -r '.printlabel_kind // ""' <<< "${netbox_object_json}")" || return 1
      netbox_object_url="$("${jq_bin}" -r '.display_url // ""' <<< "${netbox_object_json}")" || return 1
      object_name="$("${jq_bin}" -r '.name // .label // .module_type.model // .module_bay.name // ""' <<< "${netbox_object_json}")" || return 1
      asset_tag="$("${jq_bin}" -r '.asset_tag // ""' <<< "${netbox_object_json}")" || return 1
      serial_number="$("${jq_bin}" -r '.serial // ""' <<< "${netbox_object_json}")" || return 1

      if [[ -n "${simple_mode}" && -z "${asset_tag}" ]]
      then
        echo "NetBox ${netbox_object_kind} ${netbox_object_id} has no asset tag for --simple mode." >&2
        return 1
      fi

      if [[ -z "${netbox_object_url}" ]]
      then
        echo "NetBox ${netbox_object_kind} ${netbox_object_id} has no display URL." >&2
        return 1
      fi

      if [[ -z "${simple_mode}" && -z "${object_name}" ]]
      then
        echo "NetBox ${netbox_object_kind} ${netbox_object_id} has no name." >&2
        return 1
      fi

      print_netbox_summary "${jq_bin}" "${netbox_object_json}" || return 1

      render_netbox_label \
        "${image_tool}" \
        "${qr_tool}" \
        "${netbox_object_url}" \
        "${object_name}" \
        "${asset_tag}" \
        "${serial_number}" \
        "${font_name}" \
        "${qr_size}" \
        "${black_mode}" \
        "${simple_mode}" || return 1

      if [[ -n "${invert_mode}" ]]
      then
        apply_invert "${image_tool}" "${label_image}" "${label_image}" || return 1
      fi
      preview_label "${preview_mode}" || return 1
    else
      qr_tool="$(find_qrencode)" || return 1
      font_name="$(find_font)"
      label_image="$(mktemp --suffix=.png printlabel.XXXXXX)"
      trap cleanup EXIT

      if [[ ${#positional_args[@]} -gt 0 ]]
      then
        qr_label_text="${positional_args[*]}"
        render_qr_with_text \
          "${qr_text}" \
          "${qr_label_text}" \
          "${image_tool}" \
          "${qr_tool}" \
          "${font_name}" \
          "${qr_size}" \
          "${black_mode}" || return 1
      else
        render_qr "${qr_text}" "${image_tool}" "${qr_tool}" "${qr_size}" "${black_mode}" || return 1
      fi
      if [[ -n "${invert_mode}" ]]
      then
        apply_invert "${image_tool}" "${label_image}" "${label_image}" || return 1
      fi
      preview_label "${preview_mode}" || return 1
    fi
  else
    label_text="${positional_args[*]}"
    image_tool="$(find_magick)" || return 1
    font_name="$(find_font)"
    label_image="$(mktemp --suffix=.png printlabel.XXXXXX)"
    trap cleanup EXIT

    render_label "${label_text}" "${image_tool}" "${font_name}" || return 1
    if [[ -n "${invert_mode}" ]]
    then
      apply_invert "${image_tool}" "${label_image}" "${label_image}" || return 1
    fi
    preview_label "${preview_mode}" || return 1
  fi

  printer_address="$(discover_printer_address "${explicit_printer_address}")" || return 1

  if ! is_bdaddr "${printer_address}"
  then
    echo "Invalid Bluetooth MAC address: ${printer_address}" >&2
    return 2
  fi

  log_info "Using printer: ${printer_address}"
  prepare_printer_connection "${printer_address}"

  print_index=1
  while [[ "${print_index}" -le "${count}" ]]
  do
    python3 "${script_dir}/labelmaker.py" -i "${label_image}" "${labelmaker_args[@]}" "${printer_address}" || return 1
    print_index=$((print_index + 1))
  done
}

if [[ "${BASH_SOURCE[0]}" == "${0}" ]]
then
  main "$@"
fi

